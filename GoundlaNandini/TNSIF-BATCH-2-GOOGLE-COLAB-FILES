      "source": [
        "Mini Project:\n",
        "\n",
        "Create a Student Report Card Program using:\n",
        "\n",
        "1.List → store student names\n",
        "\n",
        "2.Set → store subjects\n",
        "\n",
        "3.Tuple → store student information (name, age)\n",
        "\n",
        "4.Dictionary → store subject-wise marks\n",
        "\n",
        "Requirements:\n",
        "\n",
        "1.Ask the user to enter:\n",
        "\n",
        "*Student name\n",
        "\n",
        "*Age\n",
        "\n",
        "*Number of subjects\n",
        "\n",
        "2.For each subject:\n",
        "\n",
        "*Enter subject name\n",
        "\n",
        "*Enter marks\n",
        "\n",
        "3.Store:\n",
        "\n",
        "*Name in a list\n",
        "\n",
        "*Subjects in a set\n",
        "\n",
        "*Student info in a tuple\n",
        "\n",
        "*Marks in a dictionary\n",
        "\n",
        "4.Print a report card showing:\n",
        "\n",
        "*Name\n",
        "\n",
        "*Age\n",
        "\n",
        "*Subjects\n",
        "\n",
        "*Marks\n",
        "\n",
        "*Total marks\n",
        "\n",
        "*Average marks"
      ],
      "metadata": {
        "id": "Q7R3DJUwDPvb"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "name = input(\"Enter student name: \")\n",
        "age = int(input(\"Enter age: \"))\n",
        "\n",
        "students = []\n",
        "subjects = set()\n",
        "marks = {}\n",
        "\n",
        "students.append(name)\n",
        "\n",
        "student_info = (name, age)\n",
        "\n",
        "n = int(input(\"How many subjects? \"))\n",
        "\n",
        "for i in range(n):\n",
        "    sub = input(\"Enter subject name: \")\n",
        "    mark = int(input(\"Enter marks: \"))\n",
        "\n",
        "    subjects.add(sub)\n",
        "    marks[sub] = mark\n",
        "\n",
        "total = sum(marks.values())\n",
        "average = total / len(marks)\n",
        "\n",
        "print(\"\\n----- REPORT CARD -----\")\n",
        "\n",
        "print(\"Name:\", student_info[0])\n",
        "print(\"Age:\", student_info[1])\n",
        "\n",
        "print(\"\\nSubjects:\")\n",
        "for subject in subjects:\n",
        "    print(sub)\n",
        "\n",
        "print(\"\\nMarks:\")\n",
        "for subject, mark in marks.items():\n",
        "    print(subject, \":\", mark)\n",
        "\n",
        "print(\"\\nTotal Marks:\", total)\n",
        "print(\"Average Marks:\", average)"
      ],
