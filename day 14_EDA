        "import pandas as pd\n",
        "data = {\n",
        "    \"Exam_Score\": [55,65,72,60,95,80,85,250]\n",
        "}\n",
        "\n",
        "df=pd.DataFrame(data)\n",
        "#q1=55,65,72,60 -->55,60,65,72 --> median =60+65/2=62.5\n",
        "Q1 = df[\"Exam_Score\"].quantile(0.25)\n",
        "#q2=95,80,85,250 --> 80,85,95,250 --> median = 85+95/2 = 90\n",
        "Q3 = df[\"Exam_Score\"].quantile(0.75)\n",
        "\n",
        "#iQR= 90-62.5 = 27.5\n",
        "IQR = Q3 - Q1\n",
        "\n",
        "#62.5-1.5*27.5 = 62.5-41.25 = 21.25\n",
        "lower = Q1 - 1.5 * IQR\n",
        "#90+1.5*27.5 = 90+41.25 = 131.25\n",
        "upper = Q3 + 1.5 * IQR\n",
        "\n",
        "outliers = df[\n",
        "    (df[\"Exam_Score\"] < lower) #21.25\n",
        "    (df[\"Exam_Score\"] > upper) #131.25\n",
        "]\n",
        "\n",
        "print(outliers)\n",
        "\n",
        "Q1 = df[\"Exam_Score\"].quantile(0.25)\n",
        "Q3 = df[\"Exam_Score\"].quantile(0.75)\n",
